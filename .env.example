# ==========================================
# PUBLIC TEMPLATE: bq-optim-agent
# ==========================================
# 1. Copy this file and rename it to ".env"
# 2. Fill in your specific Google Cloud and Gemini credentials below.

# --- [OPTIONAL] API Key Authentication ---
# If you are not using Vertex AI and prefer an API key, uncomment and set this:
# GEMINI_API_KEY="your-gemini-api-key-here"

# --- [REQUIRED] Vertex AI / Google Cloud Authentication ---
# Set to "True" if using Vertex AI on Google Cloud (Recommended)
GOOGLE_GENAI_USE_VERTEXAI="True"
GOOGLE_API_USE_CLIENT_CERTIFICATE="never"

# --- [REQUIRED] Agent Configuration ---
# Your Google Cloud Project ID where BigQuery Dry Runs will be executed
GOOGLE_CLOUD_PROJECT="your-gcp-project-id-here"
# The region for your Vertex AI requests (e.g., "us", "us-central1")
GOOGLE_CLOUD_LOCATION="us"
# The target Gemini model
GEMINI_MODEL="gemini-3.5-flash"

# --- [OPTIONAL] Session storage ---
# SQLAlchemy URI for ADK session persistence.
#   - Unset (default): a local SQLite file is created at <repo>/sessions.db
#   - "memory":        ephemeral in-memory store (lost on restart)
#   - Any SQLAlchemy URI, e.g. "sqlite:///./sessions.db" or
#     "postgresql+psycopg://user:pass@host/db"
# SESSION_SERVICE_URI="sqlite:///./sessions.db"
